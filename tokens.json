{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "A gesture-driven iOS app that detects claps and snaps via microphone, triggers configurable actions per profile, and supports custom gesture training with DTW pattern matching.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.318,
          0.835
        ],
        "hex": "#0051d5"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.424,
          0.447,
          0.471
        ],
        "hex": "#6c7278"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.141,
          0.541,
          0.239
        ],
        "hex": "#248a3d"
      }
    },
    "danger": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.231,
          0.188
        ],
        "hex": "#ff3b30"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.584,
          0
        ],
        "hex": "#ff9500"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.949,
          0.949,
          0.969
        ],
        "hex": "#f2f2f7"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "SF Pro Display",
        "fontSize": {
          "value": 28,
          "unit": "px"
        },
        "fontWeight": 700
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "SF Pro Text",
        "fontSize": {
          "value": 17,
          "unit": "px"
        },
        "fontWeight": 400
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "SF Pro Text",
        "fontSize": {
          "value": 12,
          "unit": "px"
        },
        "fontWeight": 400
      }
    }
  }
}
